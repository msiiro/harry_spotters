# AO3 credentials
AO3_USERNAME=your_ao3_username
AO3_PASSWORD=your_ao3_password

# Shared secret between this service and your Next.js app
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SCRAPER_SECRET=replace_with_a_long_random_string

# Comma-separated list of allowed frontend origins
# Use * for local dev, lock it down in production
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
